# Copiez ce fichier en `.env` et remplissez les valeurs.
# Ne commitez jamais `.env` (il est ignoré via .gitignore).
#
# Noms attendus : SERPER_API_KEY, ANTHROPIC_API_KEY, OPENAI_API_KEY
# (acceptés aussi : OPENAI_KEY, ANTHROPIC_KEY, CLAUDE_API_KEY, SERPER_KEY — mappés au démarrage)
# Valeurs sans guillemets de préférence : SERPER_API_KEY=sk-...
# Vérifier que le serveur voit les clés : curl -s http://127.0.0.1:8787/api/health | jq .env
# (redémarrer `npm run server` après toute modification du .env)
# Le serveur valide ces variables au démarrage et s'arrête si elles sont invalides.

# --- API locale (optionnel) ---
# PORT=8787

# --- SERP (Serper) : recherche Google, analyse concurrentielle ---
# https://serper.dev
SERPER_API_KEY=4783aa6c5d8f9ec9a3834e7e8c774480b5209c5b

# --- LLM (au moins une clé selon les tâches) ---
# https://console.anthropic.com
ANTHROPIC_API_KEY=
# https://platform.openai.com
OPENAI_API_KEY=

# --- Database (si activée dans le futur) ---
# DATABASE_URL=https://db.example.com

# --- Managed Agents (optionnel) ---
# Permet de réutiliser les mêmes resources Anthropic entre redémarrages du serveur.
# Si absent, le serveur crée un agent/environment à la volée.
# ANTHROPIC_MANAGED_AGENT_ID=agent_...
# ANTHROPIC_MANAGED_ENVIRONMENT_ID=env_...

# --- Front (optionnel) ---
# En dev, le client appelle l’API en direct sur 127.0.0.1:8787 (évite 502 du proxy Vite).
# Pour forcer le proxy Vite : VITE_USE_VITE_PROXY=1
# Autre port API : VITE_API_PORT=9000  (+ PORT=9000 côté serveur)
# VITE_API_URL=https://api.example.com

