# Copiez ce fichier en `.env` et remplissez les valeurs.
# Ne commitez jamais `.env` (il est ignoré via .gitignore).

# --- API locale (optionnel) ---
# PORT=8787

# --- SERP (Serper) : recherche Google, analyse concurrentielle ---
# https://serper.dev
SERPER_API_KEY=

# --- LLM (au moins une clé selon les tâches) ---
# https://console.anthropic.com
ANTHROPIC_API_KEY=
# https://platform.openai.com
OPENAI_API_KEY=

# --- Google Search Console (optionnel) ---
# Déposez le JSON dans credentials/google-service-account.json (ignoré) puis gardez ce chemin :
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json

# --- Front (optionnel) ---
# VITE_API_URL=http://127.0.0.1:8787

